# Etapa 1 - Build (caso tenha TypeScript)
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Etapa 2 - Produção
FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY package*.json ./
RUN npm ci --omit=dev

# Defina a porta (ex: 3000)
ENV PORT=3000
EXPOSE 3000

# Variáveis de ambiente (não coloque secretos aqui!)
ENV NODE_ENV=production

# Comando para iniciar
CMD ["node", "dist/index.js"]
