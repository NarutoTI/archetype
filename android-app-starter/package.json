{
  "name": "android-app-starter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:android": "vite --mode development",
    "build": "vue-tsc && vite build --mode production",
    "build:dev": "vue-tsc && vite build --mode development",
    "preview": "vite",
    "test:unit": "vitest",
    "lint": "eslint .",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build": "npm run build && npx cap sync",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-share-target": "^8.0.35",
    "@ionic/vue": "^8.8.8",
    "@ionic/vue-router": "^8.8.8",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.13.2",
    "capacitor-native-biometric": "^4.2.2",
    "capacitor-native-settings": "^8.1.0",
    "ionicons": "^8.0.13",
    "leaflet": "^1.9.4",
    "leaflet-geosearch": "^4.2.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.3.0",
    "eslint": "^8.35.0",
    "eslint-plugin-vue": "^9.9.0",
    "jsdom": "^22.1.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "terser": "^5.4.0",
    "typescript": "~5.6.2",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "vue-tsc": "^2.1.10"
  },
  "description": "Ionic Vue Android app starter",
  "overrides": {
    "minimatch": "9.0.7"
  }
